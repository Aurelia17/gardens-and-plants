<p style="color: green"><%= notice %></p>

<%= render @garden %>

<div class="text-center mt-5">
  <%= link_to "Edit #{@garden.name}", edit_garden_path(@garden), class: "btn btn-primary" %>
  <%= link_to "Back to gardens", gardens_path, class: "btn btn-secondary" %>

  <%= link_to "Destroy #{@garden.name}", garden_path(@garden), method: :delete, class: "btn btn-danger" %>
</div>
