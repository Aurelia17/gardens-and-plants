<p style="color: green"><%= notice %></p>

<%= render @garden %>

<div class="text-center my-5">
  <%= link_to "✏️ Edit #{@garden.name} ✏️", edit_garden_path(@garden), class: "btn btn-primary" %>
  <%= link_to "☜ Back to gardens", gardens_path, class: "btn btn-secondary" %>
  <%= link_to "🗑️ Destroy #{@garden.name} 🗑️", garden_path(@garden), method: :delete, class: "btn btn-danger" %>
  <%= link_to "🫛 Add a plant 🫛", new_garden_plant_path(@garden), class: "btn btn-success"  %>



</div>

<div class="cards">
  <% @garden.plants.each do |plant| %>
    <div class="card mb-5" style="width: 18rem;">
      <img src="<%= plant.image_url %>" class="card-img-top" alt="<%= plant.name %>">
      <div class="card-body">
        <h5 class="card-title text-center"><%= plant.name %></h5>
        <%= link_to "+", plant_path(plant), data: {turbo_method: :delete, turbo_confirm: "Are you sure you want to delete #{plant.name} 😱?"}, class: "card-remove-link" %>
      </div>
    </div>
  <% end %>
</div>
